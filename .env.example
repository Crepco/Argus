# ---- LLM synthesis ----
OPENROUTER_API_KEY=            # OpenRouter — all LLM calls

# ---- OSINT data sources ----
SERPAPI_KEY=                   # SerpAPI — 100 free searches/month
GITHUB_TOKEN=                  # GitHub PAT — free, 5000 req/hr (module scans, not auth)

# ---- Ownership verification ----
# Secret used to sign short-lived verification tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
VERIFICATION_SECRET=

# GitHub OAuth app (proves the auditor controls the GitHub account being scanned).
# Create at https://github.com/settings/developers — callback: {BACKEND_URL}/api/verify/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# SMTP for the email one-time-code. Leave blank in dev to print codes to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@osint-auditor.local

# ---- Infra / URLs ----
REDIS_URL=redis://localhost:6379/0
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ---- LLM synthesis ----
GEMINI_API_KEY=              # Google AI Studio (aistudio.google.com/apikey) — all LLM calls
OPENROUTER_API_KEY=          # unused now that llm_client.py calls Gemini directly; kept in case you switch back

# ---- OSINT data sources ----
SERPAPI_KEY=                   # SerpAPI — 100 free searches/month
GITHUB_TOKEN=                  # GitHub PAT — free, 5000 req/hr (module scans, not auth)

# ---- Ownership verification ----
# Secret used to sign short-lived verification tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
VERIFICATION_SECRET=

# GitHub OAuth app (proves the auditor controls the GitHub account being scanned).
# Create at https://github.com/settings/developers — callback: {BACKEND_URL}/api/verify/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ---- Infra / URLs ----
REDIS_URL=redis://127.0.0.1:6379/0
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
